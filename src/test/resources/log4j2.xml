<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="log.dir">target/logs</Property>
        <Property name="log.pattern">%d{yyyy-MM-dd HH:mm:ss} [%t] %-5p %c{1} - %m%n</Property>
    </Properties>

    <Appenders>
        <!-- Consola -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${log.pattern}"/>
        </Console>

        <!-- Archivo con rotación -->
        <RollingFile name="FileLogger"
                     fileName="${log.dir}/application.log"
                     filePattern="${log.dir}/application-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${log.pattern}"/>
            <Policies>
                <!-- Rotar cada día -->
                <TimeBasedTriggeringPolicy interval="1"/>
                <!-- Rotar si pasa de 10 MB -->
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Logger raíz -->
        <Root level="debug">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>

        <!-- Loggers específicos -->
        <Logger name="actions" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Logger>

        <Logger name="runners" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Logger>
    </Loggers>
</Configuration>